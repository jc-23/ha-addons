# Weekly profiles for MAX! thermostats — EXAMPLE / TEMPLATE
#
# Format: [end_time, temperature] - the temperature applies from the previous
#         slot up to the given time.
# Missing weekdays inherit from "default" (used for Mon-Fri when no specific day
# is given). Weekdays: Mon, Tue, Wed, Thu, Fri, Sat, Sun.
#
# The room keys (LivingRoom, Bathroom, ...) must match the room keys configured
# in the `devices` add-on option. The values below are placeholders — replace
# them with your own schedule.
#
# The live file is read from /config/heating_week_profile.yaml (see the
# `profiles_file` option) and stays in your Home Assistant config dir; it is not
# part of this add-on.

profiles:

  Comfort:
    LivingRoom:
      default:  [["06:00", 18.0], ["22:00", 21.0], ["24:00", 18.0]]
      Sat:      [["07:00", 18.0], ["23:00", 21.0], ["24:00", 18.0]]
      Sun:      [["07:00", 18.0], ["23:00", 21.0], ["24:00", 18.0]]
    Bathroom:
      default:  [["06:00", 18.0], ["09:00", 21.0], ["24:00", 18.0]]
    Bedroom:
      default:  [["24:00", 18.0]]

  Eco:
    LivingRoom:
      default:  [["24:00", 17.0]]
    Bathroom:
      default:  [["24:00", 17.0]]
    Bedroom:
      default:  [["24:00", 16.0]]
